# === Backend sozlamalari namunasi ===
# Ushbu faylni .env deb nusxalang va qiymatlarni to'ldiring.

# Telegram bot tokeni (@BotFather dan olinadi)
BOT_TOKEN=xxxxxxxx:yyyyyyyyyyyyyyyyyyyyyyyyyyyyyyy

# API server porti (macOS'da 5000 AirPlay tomonidan band — 5001 ishlating)
PORT=5001

# MongoDB Atlas ulanish satri.
# Atlas -> Connect -> Drivers dan aniq nusxalang.
# Format: mongodb+srv://FOYDALANUVCHI:PAROL@CLUSTER.mongodb.net/DBNOMI?retryWrites=true&w=majority
# Diqqat: parolda maxsus belgi (@ $ / :) bo'lsa URL-encode qiling.
MONGO_URI=mongodb+srv://user:password@cluster.xxxxx.mongodb.net/invitationDB?retryWrites=true&w=majority

# Taklifnoma havolasi domeni (domen olgach shu yerga yozing)
BASE_URL=https://baxt.uz

# Rasmlar shu manzildan beriladi (dev: localhost, prod: backend domeni)
API_PUBLIC_URL=http://localhost:5001

# Test (bypass) kartasi — bu karta bilan pul yechilmaydi (faqat siz sinash uchun)
TEST_CARD=1234567812345678
